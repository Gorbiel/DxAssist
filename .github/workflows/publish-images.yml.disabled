name: Publish Images

on:
  push:
    branches: ["master", "production"]
    paths-ignore:
      - "k8s/overlays/production/kustomization.yaml"
      - "k8s/overlays/staging/kustomization.yaml"

permissions:
  contents: write
  packages: write

env:
  REGISTRY: ghcr.io
  IMAGE_NAMESPACE: gorbiel/DxAssist

jobs:
  publish:
    name: Build and publish images
    runs-on: ubuntu-latest

    strategy:
      matrix:
        include:
          - name: backend
            context: ./backend
            dockerfile: ./backend/Dockerfile
            build_args: ""
          - name: frontend
            context: ./frontend
            dockerfile: ./frontend/Dockerfile
            build_args: ""

    steps:
      - name: Checkout
        uses: actions/checkout@v6

      - name: Set image tag
        id: vars
        run: |
          if [[ "${GITHUB_REF_NAME}" == "production" ]]; then
            echo "env_tag=production" >> "$GITHUB_OUTPUT"
            echo "backend_url=https://api.glazedin.click" >> "$GITHUB_OUTPUT"
          elif [[ "${GITHUB_REF_NAME}" == "master" ]]; then
            echo "env_tag=staging" >> "$GITHUB_OUTPUT"
            echo "backend_url=https://api.staging.glazedin.click" >> "$GITHUB_OUTPUT"
          else
            echo "Unsupported branch: ${GITHUB_REF_NAME}"
            exit 1
          fi

          echo "sha_tag=${GITHUB_SHA::7}" >> "$GITHUB_OUTPUT"

      - name: Log in to GHCR
        uses: docker/login-action@v4
        with:
          registry: ${{ env.REGISTRY }}
          username: ${{ github.actor }}
          password: ${{ secrets.GITHUB_TOKEN }}

      - name: Extract metadata
        id: meta
        uses: docker/metadata-action@v6
        with:
          images: ${{ env.REGISTRY }}/${{ env.IMAGE_NAMESPACE }}/${{ matrix.name }}
          tags: |
            type=raw,value=${{ steps.vars.outputs.env_tag }}
            type=raw,value=${{ steps.vars.outputs.sha_tag }}

      - name: Build and push
        uses: docker/build-push-action@v7
        with:
          context: ${{ matrix.context }}
          file: ${{ matrix.dockerfile }}
          push: true
          tags: ${{ steps.meta.outputs.tags }}
          labels: ${{ steps.meta.outputs.labels }}
          build-args: |
            ${{ matrix.build_args }}
            BACKEND_URL=${{ steps.vars.outputs.backend_url }}

  update-manifests:
    name: Update staging deployment manifest
    runs-on: ubuntu-latest
    needs: publish
    if: github.ref_name == 'master'

    steps:
      - name: Checkout
        uses: actions/checkout@v6
        with:
          ssh-key: ${{ secrets.MANIFEST_UPDATE_DEPLOY_KEY }}

      - name: Update image tags
        run: |
          overlay="k8s/overlays/staging"
          sha_tag="${GITHUB_SHA::7}"
          sed -i -E "s/(newTag: ).*/\1${sha_tag}/" "${overlay}/kustomization.yaml"

          echo "OVERLAY=${overlay}" >> "$GITHUB_ENV"
          echo "SHA_TAG=${sha_tag}" >> "$GITHUB_ENV"

      - name: Commit manifest update
        run: |
          if git diff --quiet -- "${OVERLAY}/kustomization.yaml"; then
            echo "Manifest already points to ${SHA_TAG}"
            exit 0
          fi

          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
          git add "${OVERLAY}/kustomization.yaml"
          git commit -m "chore: deploy images ${SHA_TAG}"
          git remote set-url origin "git@github.com:${GITHUB_REPOSITORY}.git"
          git push origin "HEAD:${GITHUB_REF_NAME}"
