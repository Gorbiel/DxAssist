# DxAssist Compose environment template.
# Copy this file to `.env` in the repository root and adjust values locally.
# Do not commit real secrets, passwords, hospital hostnames, or production keys.

# Compose / Django environment selector: dev, test, or production.
ENVIRONMENT=dev

# Django settings module loader. Usually keep this as config.settings.
DJANGO_SETTINGS_MODULE=config.settings

# Local development debug flag. Production-like Compose overrides this to False.
DJANGO_DEBUG=True

# Required by Django. Generate a unique value for every non-local deployment.
SECRET_KEY=change-me

# Comma-separated hostnames accepted by Django.
ALLOWED_HOSTS=backend,localhost,127.0.0.1

# Comma-separated browser origins allowed to call the API.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Comma-separated trusted origins for unsafe HTTP methods behind CSRF protection.
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# PostgreSQL credentials used by Compose and Django.
POSTGRES_DB=dxassist
POSTGRES_USER=dxassist
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Host ports exposed by Docker Compose.
BACKEND_PORT=8000
FRONTEND_PORT=3000
POSTGRES_EXPOSED_PORT=5432

# Internal URL used by the frontend container to reach the backend container.
BACKEND_URL=http://backend:8000

# Entrypoint migration retry limit.
MIGRATE_MAX_ATTEMPTS=5

# Production-only optional toggles. Set explicitly for production-like runs.
SERVE_MEDIA_FILES=false
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30
JWT_ALGORITHM=HS256
